# === Backend ===
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/miportafolio

# Auth (single user)
ADMIN_EMAIL=tu@email.com
ADMIN_PASSWORD_HASH=$2b$12$...  # bcrypt hash of your password
JWT_SECRET=cambiar-este-secreto-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=72

# APIs de datos de mercado
DATA912_BASE_URL=https://data912.com

# BCRA APIs (no requieren auth)
BCRA_API_BASE_URL=https://api.bcra.gob.ar

# estadisticasbcra.com (requiere token gratuito)
ESTADISTICAS_BCRA_TOKEN=tu-token-aqui

# DolarAPI
DOLAR_API_BASE_URL=https://dolarapi.com

# Yahoo Finance (no requiere key, usa yfinance)

# Email notifications (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASSWORD=app-password-aqui
NOTIFICATION_EMAIL=tu@email.com

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000
